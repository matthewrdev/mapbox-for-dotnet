@using System;

@{
    var homePageUrl = string.IsNullOrWhiteSpace(Model.Artifact.Nuget.HomePageUrl)
        ? Model.Artifact.Group.HomePageUrl
        : Model.Artifact.Nuget.HomePageUrl;

    var guideUrl = string.IsNullOrWhiteSpace(Model.Artifact.Nuget.GuideUrl)
        ? Model.Artifact.Group.GuideUrl
        : Model.Artifact.Nuget.GuideUrl;

    var packageId = Model.Artifact.Nuget.PackageId;
    var isMapboxPackage = Model.Artifact.Group.Id.StartsWith("com.mapbox", StringComparison.Ordinal);
    var isMapsPackage = string.Equals(packageId, "Bindings.Mapbox.Maps.AndroidNdk27", StringComparison.Ordinal);
}
@Raw("# " + Model.Artifact.Group.Name + " - " + Model.Artifact.Nuget.Name)

.NET Android binding for `@(Model.Artifact.GradleImplementation)`.[^tuyen]

## Install

@if (isMapsPackage) {
@Raw("For a .NET Android app that renders Mapbox maps, install this package:")
} else if (isMapboxPackage) {
@Raw("Most apps should install `Bindings.Mapbox.Maps.AndroidNdk27` and let NuGet bring this package in transitively. Install this package directly only when you use APIs from this Maven artifact.")
} else {
@Raw("This support binding is normally pulled in by the Mapbox packages. Install it directly only if your app uses this artifact's APIs.")
}

```bash
dotnet add package @(packageId) --version @(Model.Artifact.Version.NugetVersion)
```

@if (isMapboxPackage) {
@Raw(@"## Mapbox Setup

Mapbox Android artifacts are resolved from Mapbox's Maven repository during your app build. Add this once to the consuming app project:

```xml
<ItemGroup>
  <GradleRepository Include=""https://api.mapbox.com/downloads/v2/releases/maven"">
    <Repository><![CDATA[
      maven {
          url = uri(""https://api.mapbox.com/downloads/v2/releases/maven"")
          credentials {
              username = ""mapbox""
              password = providers.gradleProperty(""MAPBOX_DOWNLOADS_TOKEN"").orNull
          }
          authentication {
              create<BasicAuthentication>(""basic"")
          }
      }
    ]]></Repository>
  </GradleRepository>
</ItemGroup>
```

Provide the secret downloads token through Gradle, not in source control:

```bash
export ORG_GRADLE_PROJECT_MAPBOX_DOWNLOADS_TOKEN=sk...
```

You can also set `MAPBOX_DOWNLOADS_TOKEN=sk...` in `~/.gradle/gradle.properties`.

Use a public Mapbox access token at runtime before creating the map:

```csharp
Com.Mapbox.Common.MapboxOptions.AccessToken = ""pk..."";
```
")
}

@if (isMapsPackage) {
@Raw(@"## Minimal Map

```csharp
using Com.Mapbox.Common;
using Com.Mapbox.Maps;

MapboxOptions.AccessToken = ""pk..."";

var mapInitOptions = new MapInitOptions(
    this,
    MapInitOptions.CompanionField.GetDefaultMapOptions(this),
    MapInitOptions.CompanionField.DefaultPluginList,
    cameraOptions: null,
    textureView: false,
    styleUri: Style.Outdoors);

var mapView = new MapView(this, mapInitOptions);
SetContentView(mapView);
```

Keep the `MapView` in a field and forward your activity lifecycle callbacks to it (`OnStart`, `OnStop`, `OnDestroy`, and `OnLowMemory`).
")
}

