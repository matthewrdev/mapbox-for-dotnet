<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:local="clr-namespace:MapboxBindings.MauiHarness"
             x:Class="MapboxBindings.MauiHarness.MainPage">

    <Grid RowDefinitions="Auto,*,Auto" Padding="24" RowSpacing="16">
        <Label
            Text="Mapbox MAUI Harness"
            Style="{StaticResource Headline}" />

        <Border Grid.Row="1" StrokeShape="RoundRectangle 16" StrokeThickness="1" Padding="0">
            <local:MapboxMapView />
        </Border>

        <Label
            Grid.Row="2"
            Text="Set MAPBOX_ACCESS_TOKEN or pass -p:MapboxAccessToken=... when building iOS targets."
            Style="{StaticResource SubHeadline}" />
    </Grid>

</ContentPage>
